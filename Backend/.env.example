# ─────────────────────────────────────────────
#  ZyntrixCRM · Environment Variables Example
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

NODE_ENV=production
PORT=5000
JWT_SECRET=replace_with_strong_random_string_min_32_chars

# MongoDB Atlas
MONGO_URI=mongodb+srv://softwarezentrix_db_user:FFD6n4a5UP2TSHW2@cluster0.fl11xck.mongodb.net/?appName=Cluster0

# Frontend origin (must match exactly — no trailing slash)
FRONTEND_URL=https://zyntrixsoftware.com

# ── Email (Office365 / Outlook) ──────────────────────────────────
DEV_SKIP_EMAIL=false
EMAIL_USER=your-login@zyntrixsoftware.com
EMAIL_PASS=your-password
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_FROM=noreply@zyntrixsoftware.com
EMAIL_SENDER_NAME=Zyntrix CRM

# ── Optional: restrict forgot-password to company domain ─────────
ALLOWED_EMAIL_DOMAIN=zyntrixsoftware.com

# ── Google Apps Script web app (syncs shortlist status to Sheet) ─
GAS_WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# ── Payroll rates ────────────────────────────────────────────────
HOURLY_RATE=200
HRA_PERCENT=0.20
TAX_PERCENT=0.10
OVERTIME_MULTIPLIER=1.5
OVERTIME_BONUS_THRESHOLD_HOURS=10
OVERTIME_BONUS_AMOUNT=1000
